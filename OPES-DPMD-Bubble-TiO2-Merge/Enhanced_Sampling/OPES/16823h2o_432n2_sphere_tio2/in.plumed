bubB_all: CENTER ATOMS=b001,b002,b003,b004,b005,b006,b007,b008,b009,b010,b011,b012,b013,b014,b015,b016,b017,b018,b019,b020,b021,b022,b023,b024,b025,b026,b027,b028,b029,b030,b031,b032,b033,b034,b035,b036,b037,b038,b039,b040,b041,b042,b043,b044,b045,b046,b047,b048,b049,b050,b051,b052,b053,b054,b055,b056,b057,b058,b059,b060,b061,b062,b063,b064,b065,b066,b067,b068,b069,b070,b071,b072,b073,b074,b075,b076,b077,b078,b079,b080,b081,b082,b083,b084,b085,b086,b087,b088,b089,b090,b091,b092,b093,b094,b095,b096,b097,b098,b099,b100,b101,b102,b103,b104,b105,b106,b107,b108,b109,b110,b111,b112,b113,b114,b115,b116,b117,b118,b119,b120,b121,b122,b123,b124,b125,b126,b127,b128,b129,b130,b131,b132,b133,b134,b135,b136,b137,b138,b139,b140,b141,b142,b143,b144,b145,b146,b147,b148,b149,b150,b151,b152,b153,b154,b155,b156,b157,b158,b159,b160,b161,b162,b163,b164,b165,b166,b167,b168,b169,b170,b171,b172,b173,b174,b175,b176,b177,b178,b179,b180,b181,b182,b183,b184,b185,b186,b187,b188,b189,b190,b191,b192,b193,b194,b195,b196,b197,b198,b199,b200,b201,b202,b203,b204,b205,b206,b207,b208,b209,b210,b211,b212,b213,b214,b215,b216
d3d_all: DISTANCE ATOMS=bubA_all,bubB_all

# ----------------------------------------------------------------------------
# C. Per-bubble cluster-integrity channels (A and B separated)
# ----------------------------------------------------------------------------
matA: CONTACT_MATRIX ATOMS=repsA SWITCH={CUBIC D_0=5.0 D_MAX=6.0}
dfsA: DFSCLUSTERING MATRIX=matA LOWMEM
n2A_num: CLUSTER_NATOMS CLUSTERS=dfsA CLUSTER=1
sumA_cn: CLUSTER_PROPERTIES CLUSTERS=dfsA CLUSTER=1 SUM

matB: CONTACT_MATRIX ATOMS=repsB SWITCH={CUBIC D_0=5.0 D_MAX=6.0}
dfsB: DFSCLUSTERING MATRIX=matB LOWMEM
n2B_num: CLUSTER_NATOMS CLUSTERS=dfsB CLUSTER=1
sumB_cn: CLUSTER_PROPERTIES CLUSTERS=dfsB CLUSTER=1 SUM

wO: GROUP ATOMS=13201-63667:3
mid_all: CENTER ATOMS=bubA_all,bubB_all
wcn_bridge: COORDINATIONNUMBER SPECIES=wO R_0=3.2 NN=6 MM=12
bridge_cyl_env: INCYLINDER ATOM=mid_all DATA=wcn_bridge DIRECTION=X RADIUS={TANH R_0=6.5} LOWER=-8.0 UPPER=8.0 KERNEL=gaussian MEAN SUM

OPES_METAD_EXPLORE ...
  RESTART=NO
  LABEL=opes_e
  ARG=d3d_all
  FILE=HILLS_e
  TEMP=330
  PACE=500
  BARRIER=50
  STATE_WFILE=STATE_e
  STATE_WSTRIDE=5000
  STORE_STATES
  WALKERS_MPI
... OPES_METAD_EXPLORE

OPES_METAD ...
  RESTART=NO
  LABEL=opes
  ARG=d3d_all
  FILE=HILLS
  TEMP=330
  PACE=500
  BARRIER=100
  STATE_WFILE=STATE
  STATE_WSTRIDE=5000
  STORE_STATES
  WALKERS_MPI
... OPES_METAD

# Output for monitoring/debug
PRINT STRIDE=1  FILE=COLVAR ARG=d3d_all,bridge_cyl_env.sum,opes.bias,opes_e.bias
PRINT STRIDE=1  FILE=COLVAR_post ARG=n2A_num,n2B_num,sumA_cn.sum,sumB_cn.sum,bridge_cyl_env.mean
FLUSH STRIDE=1000
